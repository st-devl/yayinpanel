    "@types/node": "latest",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/twitter-text": "^3.1.10",
    "autoprefixer": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "latest",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "postcss": "^8.5.15"
