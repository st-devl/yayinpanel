{
  "name": "patlat",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:ui": "playwright test",
    "compare:design": "node --env-file=.env scripts/compare-design-screenshots.mjs",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.mjs",
    "seed:demo": "node --conditions=react-server --env-file=.env --import tsx prisma/demo-seed.ts",
    "scheduler": "node --conditions=react-server --env-file=.env --import tsx scheduler.ts",
    "scheduler:dry": "node --conditions=react-server --env-file=.env --import tsx scheduler.ts --dry-run"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "latest",
    "class-variance-authority": "latest",
    "clsx": "latest",
    "date-fns": "latest",
    "date-fns-tz": "latest",
    "lucide-react": "latest",
    "mammoth": "^1.12.0",
    "next": "^16.2.7",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "server-only": "^0.0.1",
    "sharp": "latest",
    "tailwind-merge": "latest",
    "twitter-text": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
